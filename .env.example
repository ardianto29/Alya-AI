# LM Studio (atau OpenAI-compatible server) endpoint
# Ganti ke IP/host yang sesuai. Kalau localhost: http://127.0.0.1:1234/v1
LM_STUDIO_URL=http://<HOST_OR_IP>:1234/v1
LM_STUDIO_API_KEY=lm-studio
MODEL_NAME=<model-id-di-lm-studio>

# Generation params
TEMPERATURE=0.8
MAX_TOKENS=512

# Max conversation turns yang dikirim sebagai context
HISTORY_TURNS=12

# Fish Audio cloud API key (untuk akses cloud TTS — optional, gak dipakai kalau pakai F5-TTS lokal)
API_FISH_AUDIO=

# F5-TTS service (jalan di PC kantor / wherever you host f5-tts server)
TTS_URL=http://<HOST_OR_IP>:8001
TTS_VOICE=calm
TTS_ENABLED=true
TTS_TIMEOUT=60

# faster-whisper STT service (voice input, push-to-talk dari browser)
# language: 'ja' / 'id' / 'en' atau 'auto' biar Whisper detect sendiri
STT_URL=http://<HOST_OR_IP>:8002
STT_LANGUAGE=ja
STT_ENABLED=true
STT_TIMEOUT=60
